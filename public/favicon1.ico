<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Aura Logo</title>
<style>
  body {
    background-color: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    margin: 0;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    background-color: #7f0df2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-diamond {
    width: 18px;
    height: 18px;
    background-color: #ffffff;
    border-radius: 3px;
    transform: rotate(45deg);
  }
</style>
</head>
<body>
  <div class="logo-icon">
    <div class="logo-diamond"></div>
  </div>
</body>
</html>